{"root":{"data":{"id":"dh9dq575yow0","created":1774189606254,"text":"fishbot_description"},"children":[{"data":{"id":"dh9dqd1j3ds0","created":1774189623328,"text":"gazebo_launch"},"children":[{"data":{"id":"dh9dqhj9kuw0","created":1774189633107,"text":"获取xacro文件路径"},"children":[{"data":{"id":"dh9dqttollk0","created":1774189659859,"text":"将xacro模型文件转换为urdf文件的字符串格式"},"children":[{"data":{"id":"dh9dr9swiuo0","created":1774189694640,"text":"robot_state_publisher获取到urdf文件并且发布其中的关节信息（动态信息未发布）"},"children":[{"data":{"id":"dh9ds311gc80","created":1774189758259,"text":"启动gazebo的子launch文件，将世界地图等参数传入，加载基本的仿真地图"},"children":[{"data":{"id":"dh9dsqlnrpc0","created":1774189809572,"text":"启动节点，获取robot_state_publisher发布的话题，然后加载到gazebo仿真环境中","layout_right_offset":{"x":-64,"y":248}},"children":[{"data":{"id":"dh9dsx7ahz40","created":1774189823940,"text":"创建一个延时函数","layout_right_offset":{"x":-914,"y":4}},"children":[{"data":{"id":"dh9dszqdhls0","created":1774189829448,"text":"创建执行进程，等同于终端输入指令，","layout_right_offset":{"x":-562,"y":1}},"children":[]}]}]}]}]}]}]}]}]},"template":"default","theme":"fresh-blue","version":"1.4.43"}